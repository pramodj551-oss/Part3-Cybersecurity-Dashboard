# ==========================================================
# AI-Powered Cybersecurity Dashboard
# .gitignore
# ==========================================================

# ----------------------------------------------------------
# Python
# ----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ----------------------------------------------------------
# Virtual Environments
# ----------------------------------------------------------
venv/
.venv/
env/
ENV/

# ----------------------------------------------------------
# Jupyter Notebook
# ----------------------------------------------------------
.ipynb_checkpoints/

# ----------------------------------------------------------
# VS Code
# ----------------------------------------------------------
.vscode/

# ----------------------------------------------------------
# PyCharm
# ----------------------------------------------------------
.idea/

# ----------------------------------------------------------
# Operating System Files
# ----------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ----------------------------------------------------------
# Python Distribution
# ----------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
logs/
*.log

# ----------------------------------------------------------
# Streamlit Cache
# ----------------------------------------------------------
.streamlit/secrets.toml

# ----------------------------------------------------------
# Models
# (Ignore trained models if generated locally)
# ----------------------------------------------------------
models/*.pkl
models/*.joblib

# ----------------------------------------------------------
# Outputs
# ----------------------------------------------------------
outputs/
*.csv
*.xlsx
*.json

# ----------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------
*.tmp
*.temp
*.bak
*.swp

# ----------------------------------------------------------
# Environment Variables
# ----------------------------------------------------------
.env
.env.*

# ----------------------------------------------------------
# Coverage & Testing
# ----------------------------------------------------------
.coverage
.pytest_cache/
htmlcov/

# ----------------------------------------------------------
# Type Checking
# ----------------------------------------------------------
.mypy_cache/

# ----------------------------------------------------------
# Miscellaneous
# ----------------------------------------------------------
.cache/
